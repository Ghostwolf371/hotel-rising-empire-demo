# Copy to `.env` for local development.

# SQLite (default). For production use PostgreSQL and set provider in prisma/schema.prisma.
DATABASE_URL="file:./prisma/dev.db"

# Required in production: all /api/v1/* routes validate this Bearer token.
# Leave unset in local dev to skip auth (see lib/server/api-auth.ts).
HRE_API_SECRET=

# When true, guest + management UIs load and persist domain data via Prisma (Server Actions).
# Requires DATABASE_URL and `npx prisma migrate dev` + `npx prisma db seed` (or existing data).
# Also enables ~3.5s polling on /management/* so room grid + order/session popups update from the tablet without refresh.
HRE_USE_DATABASE=false
